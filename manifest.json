{
  "manifest_version": 3,
  "name": "Servpro Tools",
  "description": "Tools for Servpro WorkCenter.",
  "version": "0.2.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.servpronet.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.servpronet.io/*"
      ],
      "js": [
        "src/lib/selectors.js",
        "src/lib/kendoHelpers.js",
        "src/ui/panel.js",
        "src/content/topPage.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.servpronet.io/*"
      ],
      "all_frames": true,
      "js": [
        "src/lib/selectors.js",
        "src/lib/kendoHelpers.js",
        "src/ui/panel.js",
        "src/content/docsFrame.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
