{
  "manifest_version": 3,
  "name": "ServPro Helper - WorkCenter Help",
  "description": "Helper tools for Servpro WorkCenter uploads.",
  "version": "0.4.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ServPro Helper",
    "default_icon": {
      "16": "favicon-16x16.png",
      "32": "favicon-32x32.png",
      "48": "icon-48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "favicon-16x16.png",
    "32": "favicon-32x32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.servpronet.io/*",
    "https://teamallenssm.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.servpronet.io/*"
      ],
      "js": [
        "src/lib/settings.js",
        "src/lib/workcenterFields.js",
        "src/lib/selectors.js",
        "src/lib/kendoHelpers.js",
        "src/ui/panel.js",
        "src/ui/importPayloadPanel.js",
        "src/content/topPage.js",
        "src/content/workcenterScraper.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.servpronet.io/*"
      ],
      "all_frames": true,
      "js": [
        "src/lib/selectors.js",
        "src/lib/kendoHelpers.js",
        "src/ui/panel.js",
        "src/content/docsFrame.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://teamallenssm.com/*"
      ],
      "all_frames": true,
      "js": [
        "src/lib/settings.js",
        "src/lib/workcenterFields.js",
        "src/lib/selectors.js",
        "src/ui/importPayloadPanel.js",
        "src/content/teamallenssmFill.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
