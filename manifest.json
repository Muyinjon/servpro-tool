{
  "manifest_version": 3,
  "name": "ServPro Helper",
  "description": "Workflow tools for SERVPRO franchises — job import, FNOL, and WorkCenter integration.",
  "version": "0.8.1",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ServPro Helper",
    "default_icon": {
      "16": "favicon-16x16.png",
      "32": "favicon-32x32.png",
      "48": "icon-48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "favicon-16x16.png",
    "32": "favicon-32x32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.servpronet.io/*",
    "https://em.alacrity.net/*",
    "https://teamallenssm.com/*",
    "https://docs.google.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/ui/theme.css"],
      "matches": [
        "https://*.servpronet.io/*",
        "https://em.alacrity.net/*",
        "https://teamallenssm.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.servpronet.io/*"
      ],
      "js": [
        "src/lib/settings.js",
        "src/lib/tenantRegistry.js",
        "src/lib/workcenterFields.js",
        "src/lib/selectors.js",
        "src/lib/kendoHelpers.js",
        "src/lib/payloadPlainText.js",
        "src/lib/buttonHints.js",
        "src/ui/theme.js",
        "src/ui/helperPanel.js",
        "src/ui/panel.js",
        "src/ui/importPayloadPanel.js",
        "src/content/topPage.js",
        "src/content/workcenterScraper.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.servpronet.io/*"
      ],
      "all_frames": true,
      "js": [
        "src/lib/selectors.js",
        "src/lib/kendoHelpers.js",
        "src/ui/panel.js",
        "src/content/docsFrame.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://em.alacrity.net/*"
      ],
      "js": [
        "src/lib/settings.js",
        "src/lib/tenantRegistry.js",
        "src/lib/workcenterFields.js",
        "src/lib/alacrityFields.js",
        "src/lib/selectors.js",
        "src/lib/kendoHelpers.js",
        "src/lib/payloadPlainText.js",
        "src/lib/buttonHints.js",
        "src/ui/theme.js",
        "src/ui/helperPanel.js",
        "src/ui/panel.js",
        "src/ui/importPayloadPanel.js",
        "src/content/alacrityScraper.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://teamallenssm.com/*"
      ],
      "all_frames": true,
      "js": [
        "src/lib/settings.js",
        "src/lib/tenantRegistry.js",
        "src/lib/workcenterFields.js",
        "src/lib/selectors.js",
        "src/lib/payloadPlainText.js",
        "src/lib/fnolNotes.js",
        "src/lib/buttonHints.js",
        "src/ui/theme.js",
        "src/ui/helperPanel.js",
        "src/ui/importPayloadPanel.js",
        "src/content/teamallenssmFill.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
